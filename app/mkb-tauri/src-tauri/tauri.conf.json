{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mkb",
  "version": "0.2.0",
  "identifier": "dev.mkb.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "mkb",
        "width": 1100,
        "height": 780,
        "minWidth": 700,
        "minHeight": 500,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "bin/mkbd*",
      "bin/mkb-mcp*",
      "bin/mkb-cli*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
