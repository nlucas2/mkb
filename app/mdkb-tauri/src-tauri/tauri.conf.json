{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mdkb",
  "version": "0.1.0",
  "identifier": "dev.mdkb.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "mdkb",
        "width": 1100,
        "height": 780,
        "minWidth": 700,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "bin/mdkbd*",
      "bin/mdkb-mcp*",
      "bin/mdkb-cli*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
