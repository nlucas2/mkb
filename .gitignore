app/mdkb-tauri/src-tauri/bin/

# OS
.DS_Store
Thumbs.db

# fastembed's local model cache (created by ad-hoc runs; never committed)
.fastembed_cache/
app/mdkb-tauri/src-tauri/target/
app/mdkb-tauri/src-tauri/gen/
