# Build artifacts (the giant one — never ship the local target/ into the build context)
target/
**/target/
app/mkb-tauri/src-tauri/target/

# Local mkb index/socket/lock — rebuildable cache, never part of the build (it would also drag a
# stale Unix socket + sqlite WAL into the context and make the docs-as-data gate non-deterministic)
**/.mkb/

# Git metadata
.git/
.gitignore

# IDE / editor / OS cruft
.vscode/
.idea/
.DS_Store
*.swp

# Local config / scratch
.env
.env.*
.copilot/
plan.md
Dockerfile.trixie

# Docker / CI files aren't needed inside the build context
Dockerfile
.dockerignore
.forgejo/
